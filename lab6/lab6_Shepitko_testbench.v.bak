module test_sum;
    // Test registers and wires
    reg [4:0] Ain_r, Bin_r;
    reg Ci_r;
    wire [4:0] Ain, Bin;
    wire Ci;
    wire [4:0] res_my, res_ref;
    wire cm, cr;

    assign Ain = Ain_r;
    assign Bin = Bin_r;
    assign Ci = Ci_r;

    // Instantiate the modules to be tested
    my_sum my_block (Ain, Bin, Ci, res_my, cm);    // Structural adder
    ref_sum ref_block (Ain, Bin, Ci, res_ref, cr); // Behavioral reference model

    initial begin
        $display("Time\tAin  \tBin  \tCi\tres_my\tcm\tres_ref\tcr");
        // ?????? ?????? ?????????? ??? 5 ??? (%05b)
        $monitor("%4d\t%05b\t%05b\t%b\t%05b\t%b\t%05b\t%b",
                 $time, Ain, Bin, Ci, res_my, cm, res_ref, cr);
        #500 $finish;
    end

    // Initial block for Ain stimulus
    initial begin
        // Test various values for Ain (max 5-bit value is 31)
        Ain_r = 5'b00001;      // 1
        #50 Ain_r = 5'b01010;  // 10
        #50 Ain_r = 5'b10101;  // 21
        #50 Ain_r = 5'b11111;  // 31
        #50 Ain_r = 5'b00000;  // 0
        #50 Ain_r = 5'b10000;  // 16
        #50 Ain_r = 5'b01111;  // 15
    end

    // Initial block for Bin stimulus
    initial begin
        // Test various values for Bin
        Bin_r = 5'b00010;      // 2
        #50 Bin_r = 5'b01100;  // 12
        #50 Bin_r = 5'b10101;  // 21
        #50 Bin_r = 5'b11110;  // 30
        #100 Bin_r = 5'b00001; // 1
        #100 Bin_r = 5'b11111; // 31
    end

    // Initial block for Carry-in stimulus
    initial begin
        // Test with and without carry-in
        Ci_r = 1'b0;
        #250 Ci_r = 1'b1;
    end
endmodule
