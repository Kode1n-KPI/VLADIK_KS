// ?????? 5-?????????? ???????? (??????????? ??????)
module ref_sum (Ain, Bin, Ci, Sout, Co);
    input [4:0] Ain, Bin;
    input Ci;
    output [4:0] Sout;
    output Co;
    reg [5:0] S;

    // ?????????? ???? ?? ????????????? ?????
    always @ (Ain or Bin or Ci)
        S = Ain + Bin + Ci;

    // ???????? ??????????: ??????? 5 ??? - ????, ??????? ??? - ???????????
    assign Sout = S[4:0];
    assign Co = S[5];
endmodule
