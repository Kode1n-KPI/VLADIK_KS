// ?????? ??????????????? ?????????? (4 ?? 16)
module decoder4_16 (
    input [3:0] in,      // 4-????????? ????
    input enable,        // ?????? ??????? (???? 0, ??? ?????? 0)
    output reg [15:0] out // 16-????????? ?????
);

    always @(*) begin
        if (enable) begin
            // ?????????????? ???????? ????? ??? ????????? ?????????? ????
            out = 16'b1 << in;
        end else begin
            // ???? ?????????? ???????? ? ?? ???? ??????? ????
            out = 16'b0;
        end
    end

endmodule
