// ???????? ??? ??????????? 4x16
`timescale 1ns / 1ps

module tb_decoder_4x16;

    // ??????? ??? ??????????? ?? DUT
    reg [3:0] in;
    reg en;
    wire [15:0] out;

    // ???????????? ??????, ?? ??????????
    decoder_4x16 dut (
        .in(in),
        .en(en),
        .out(out)
    );

    // ?????? ??? ?????????? ??????????? ???????? ??????
    reg [15:0] expected_out;

    // ?????? ??????????? (??? ????????? ? ???????)
    initial begin
        $monitor("Time = %0t, en = %b, in = %b (%0d), out = %b, expected = %b",
                 $time, en, in, in, out, expected_out);
    end

    // ???????? ?????? ??????????
    initial begin
        // ???????? ????????? ?????????
        $display("=== Starting 4-to-16 Decoder Testbench ===");
        
        // ---- ???? 1: en = 0, ??? ?????? ??????? ???? 0 ----
        en = 0;
        for (in = 0; in < 16; in = in + 1) begin
            #10;  // ???????? ??? ????????????
            expected_out = 16'b0;
            if (out !== expected_out) begin
                $display("ERROR: en=0, in=%0d: out=%b, expected=%b", in, out, expected_out);
            end
        end

        // ---- ???? 2: en = 1, ????????? ???? ?????? ----
        en = 1;
        for (in = 0; in < 16; in = in + 1) begin
            #10;
            expected_out = 16'b1 << in;   // 1 ??????? ?? in ???????
            if (out !== expected_out) begin
                $display("ERROR: en=1, in=%0d: out=%b, expected=%b", in, out, expected_out);
            end
        end

        // ---- ???? 3: ????????? ????????? (?? ????????) ----
        // ?????????, ????? en ??? ??? ??????????? in
        #10;
        in = 4'd5;
        en = 0;
        #10;
        expected_out = 16'b0;
        if (out !== expected_out) $display("ERROR: en disabled check failed");
        
        en = 1;
        #10;
        expected_out = 16'b1 << 5;
        if (out !== expected_out) $display("ERROR: en enabled check failed");

        // ?????????? ??????????
        #20;
        $display("=== Testbench finished ===");
        $finish;
    end

endmodule